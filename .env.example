# ============================================================
# KEZA — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local dans git
# ============================================================

# ── Travelpayouts (prix de vols) ────────────────────────────
# https://www.travelpayouts.com/ → API → Token
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# ── Duffel (prix de vols en temps réel, HIGH confidence) ───
# https://duffel.com/ → Dashboard → API tokens
# Sans cette clé, Duffel est silencieusement désactivé (résultats LOW confidence uniquement)
DUFFEL_API_KEY=your_duffel_api_key_here

# ── Upstash Redis (cache + rate limiting + alertes) ─────────
# https://console.upstash.com/ → Database → REST API
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ── Resend (emails transactionnels — alertes, onboarding) ───
# https://resend.com/ → API Keys
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM_EMAIL=noreply@keza.app
RESEND_FROM_DOMAIN=keza.app

# ── Sentry (monitoring erreurs) ─────────────────────────────
# https://sentry.io/ → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your_key@sentry.io/your_project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project_id
# https://sentry.io/ → Account → API → Auth Tokens
SENTRY_AUTH_TOKEN=sntryu_your_auth_token_here
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ── Push notifications (Web Push / VAPID) ───────────────────
# Générer avec : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:contact@keza.app

# ── Unsplash (photos destinations) ──────────────────────────
# https://unsplash.com/developers → Your applications → Access Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── LemonSqueezy (paiements Pro) ────────────────────────────
# https://app.lemonsqueezy.com/ → Settings → API
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_VARIANT_ID=your_variant_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# ── Sécurité (générer avec : openssl rand -hex 32) ──────────
# Secret pour les routes /api/admin/*
ADMIN_SECRET=generate_with_openssl_rand_hex_32
# Secret pour les routes /api/cron/* (différent de ADMIN_SECRET)
CRON_SECRET=generate_with_openssl_rand_hex_32_different
# Secret pour les tokens d'alertes email
ALERT_TOKEN_SECRET=generate_with_openssl_rand_hex_32
# Secret HMAC pour les webhooks
HMAC_SECRET=generate_with_openssl_rand_hex_32

# ── Discord (notifications internes) ────────────────────────
# https://discord.com/ → Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# ── URLs (optionnel en local, requis en production) ─────────
NEXT_PUBLIC_APP_URL=https://keza.app
NEXT_PUBLIC_SITE_URL=https://keza.app
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=keza.app
# BASE_URL est injecté automatiquement par Vercel (VERCEL_URL)

# ── Debug (ne pas activer en production) ────────────────────
# KEZA_DEBUG_PROGRAMS=1   # active console.log par vol enrichi — très verbeux
