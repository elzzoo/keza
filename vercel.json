{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci",
  "env": {
    "NODE_ENV": "production",
    "VERCEL_ENV": "production"
  },
  "crons": [
    {
      "path": "/api/cron/alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/trial-reminder",
      "schedule": "0 9 * * *"
    }
  ],
  "github": {
    "enabled": true,
    "autoAlias": true,
    "autoAssignCustomDomains": false,
    "autoCommentTeamOnPR": true,
    "autoCreateIssueForFailure": false
  }
}
